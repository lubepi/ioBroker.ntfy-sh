{
    "root": true,
    "env": {
        "node": true,
        "es2022": true,
        "mocha": true,
        "browser": true,
        "jquery": true
    },
    "extends": [
        "eslint:recommended"
    ],
    "globals": {
        "Blockly": "readonly",
        "systemLang": "readonly",
        "systemDictionary": "writable",
        "main": "readonly",
        "systemConfig": "readonly",
        "_" : "readonly",
        "M": "readonly",
        "sendTo": "readonly",
        "instance": "readonly",
        "onChange": "readonly"
    },
    "rules": {
        "no-console": "off",
        "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
        "no-redeclare": "off"
    },
    "overrides": [
        {
            "files": ["admin/*.js"],
            "rules": {
                "no-unused-vars": "off"
            }
        }
    ]
}
